{
  "type": "module",
  "name": "file-store",
  "version": "1.0.0",
  "description": "文件管理系统",
  "scripts": {
    "build": "pnpm -r build && tsx ./scripts/moveDist.ts",
    "dev": "pnpm -r dev",
    "dev:server": "cd ./packages/server && node --run dev",
    "debug:server": "cd ./packages/server && node --run debug",
    "dev:web": "cd ./packages/web && node --run dev",
    "test": "pnpm run type-check",
    "type-check": "pnpm run type-check:common && pnpm run type-check:server && pnpm run type-check:web",
    "type-check:common": "pnpm --dir packages/common exec tsc --noEmit -p tsconfig.json --pretty false",
    "type-check:server": "pnpm --dir packages/server exec tsc --noEmit -p tsconfig.json --pretty false",
    "type-check:web": "pnpm --dir packages/web type-check",
    "init:db": "cd ./packages/server && node --run init:db",
    "init:root": "cd ./packages/server && node --run init:root",
    "key": "cd ./packages/server && node --run key",
    "key:pair": "cd ./packages/server && node --run key:pair"
  },
  "author": "feiYu <feiyucode@gmail.com>",
  "license": "MIT",
  "keywords": [
    "uxiu",
    "uxiu-cli"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "axios": "^1.18.1",
    "core-js": "^3.49.0",
    "dayjs": "^1.11.21",
    "event-imt": "0.2.7",
    "json5": "^2.2.3",
    "mime": "^4.1.0",
    "uxiu": "0.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^26.1.1",
    "fs-extra": "^11.3.6",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}